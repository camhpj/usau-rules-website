{
	"name": "usau-rules-website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:scripts": "tsc -p tsconfig.scripts.json",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"ingest": "tsx scripts/ingest/index.ts",
		"validate:content": "tsx scripts/validate-content.ts",
		"seed:questions": "tsx scripts/seed-questions/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply usau-rules-website-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply usau-rules-website-db --remote"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260710.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/barlow-condensed": "^5.2.8",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^26.1.1",
		"cheerio": "^1.2.0",
		"drizzle-kit": "^0.31.10",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	},
	"dependencies": {
		"better-auth": "^1.6.23",
		"bits-ui": "^2.18.1",
		"drizzle-orm": "^0.45.2",
		"minisearch": "^7.2.0",
		"zod": "^4.4.3"
	}
}
